@baseUrl = https://localhost:60711

### Generate — small batch, fast (5 epochs for quick smoke test)
POST {{baseUrl}}/api/Synthetic/Generate
Content-Type: application/json

{
  "numSamples": 5,
  "trainingEpochs": 5
}

### Generate — standard POC run (15 samples, 30 epochs)
POST {{baseUrl}}/api/Synthetic/Generate
Content-Type: application/json

{
  "numSamples": 15,
  "trainingEpochs": 30
}

### Generate — larger batch for stat comparison (50 samples, 50 epochs)
POST {{baseUrl}}/api/Synthetic/Generate
Content-Type: application/json

{
  "numSamples": 50,
  "trainingEpochs": 50
}

### Generate — max allowed (200 samples)
POST {{baseUrl}}/api/Synthetic/Generate
Content-Type: application/json

{
  "numSamples": 200,
  "trainingEpochs": 30
}
