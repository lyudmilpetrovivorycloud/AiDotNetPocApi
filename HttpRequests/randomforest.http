@baseUrl = https://localhost:60711

# Features: sqft, bedrooms, bathrooms, garageSpaces, ageYears

### Predict — four houses with known prices (error % reported)
POST {{baseUrl}}/api/RandomForest/Predict
Content-Type: application/json

{
  "houses": [
    { "features": [1800, 3, 2, 2,  5], "actualPrice": 261400 },
    { "features": [2500, 5, 3, 2,  3], "actualPrice": 374200 },
    { "features": [900,  1, 1, 0, 45], "actualPrice": 85000  },
    { "features": [3200, 6, 4, 3,  1], "actualPrice": 476000 }
  ]
}

