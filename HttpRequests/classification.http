@baseUrl = https://localhost:60711

# Features: wordCount, capsRatio, exclamations, urlCount, moneyKeywords, urgencyKeywords, linkRatio, avgWordLen

### Predict — two clear spam samples with ground-truth labels
POST {{baseUrl}}/api/Classification/Predict
Content-Type: application/json

{
  "samples": [
    { "features": [22,  0.62, 7, 5, 4, 3, 0.45, 3.2], "label": 1 },
    { "features": [35,  0.60, 5, 3, 3, 2, 0.35, 3.8], "label": 1 }
  ]
}

